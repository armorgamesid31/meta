  createdAt         DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @db.Timestamp(6)
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  salon             Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  offers            WaitlistOffer[]

  @@index([salonId, requestDate, status, createdAt], map: "idx_waitlist_entry_day_status_created")
  @@index([customerId, salonId], map: "idx_waitlist_entry_customer_salon")
}

model WaitlistOffer {
  id                Int                 @id @default(autoincrement())
  waitlistEntryId   Int
  salonId           Int
  token             String              @unique(map: "uq_waitlist_offer_token")
  channel           WaitlistOfferChannel
  status            WaitlistOfferStatus @default(PENDING)
  slotDate          DateTime            @db.Date
  slotStartMinute   Int
  slotEndMinute     Int
  slotPayload       Json
  offerUrl          String?
  providerMessageId String?
  failureReason     String?
  expiresAt         DateTime            @db.Timestamp(6)
  sentAt            DateTime?           @db.Timestamp(6)
  acceptedAt        DateTime?           @db.Timestamp(6)
  rejectedAt        DateTime?           @db.Timestamp(6)
  failedAt          DateTime?           @db.Timestamp(6)
  createdAt         DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  salon             Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  waitlistEntry     WaitlistEntry       @relation(fields: [waitlistEntryId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, slotDate, status, expiresAt], map: "idx_waitlist_offer_day_status_exp")
  @@index([waitlistEntryId, createdAt], map: "idx_waitlist_offer_entry_created")
}

model UserNotificationPreference {
  id           Int       @id @default(autoincrement())
  salonId      Int
  userId       Int
  masterEnabled Boolean  @default(true)
  eventConfig  Json?
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([salonId, userId], map: "uq_user_notification_pref_salon_user")
}

model AppNotification {
  id          Int                 @id @default(autoincrement())
  salonId     Int
  eventType   NotificationEventType
  title       String
  body        String
  payload     Json?
  createdAt   DateTime?           @default(now()) @db.Timestamp(6)
  expiresAt   DateTime?           @db.Timestamp(6)

  @@index([salonId, createdAt], map: "idx_app_notification_salon_created")
}

model AppNotificationDelivery {
  id              Int                          @id @default(autoincrement())
  notificationId  Int
  salonId         Int
  userId          Int
  pushTokenId     Int?
  channel         NotificationDeliveryChannel
  status          NotificationDeliveryStatus   @default(PENDING)
  providerMessageId String?
  failureReason   String?
  readAt          DateTime?                    @db.Timestamp(6)
  createdAt       DateTime?                    @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?                    @default(now()) @updatedAt @db.Timestamp(6)

  @@index([notificationId], map: "idx_notification_delivery_notification")
  @@index([salonId, userId, readAt], map: "idx_notification_delivery_user_read")
}

model HandoverAlertState {
  id                 Int       @id @default(autoincrement())
  salonId            Int
  channel            ChannelType
  conversationKey    String
  state              HandoverAlertLifecycleState @default(ACTIVE)
  repeatCount        Int       @default(0)
  firstTriggeredAt   DateTime? @db.Timestamp(6)
  lastTriggeredAt    DateTime? @db.Timestamp(6)
  lastHumanMessageAt DateTime? @db.Timestamp(6)
  stoppedAt          DateTime? @db.Timestamp(6)
  createdAt          DateTime? @default(now()) @db.Timestamp(6)
  updatedAt          DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([salonId, channel, conversationKey], map: "uq_handover_alert_salon_channel_key")
  @@index([state, updatedAt], map: "idx_handover_alert_state_updated")
}

model PermissionDefinition {
  id          Int       @id @default(autoincrement())
  key         String    @unique(map: "uq_permission_definition_key")
  module      String
  description String?
  isCritical  Boolean   @default(false)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
}

model SalonRolePermission {
  id              Int       @id @default(autoincrement())
  salonId         Int
  role            String
  permissionId    Int
  granted         Boolean   @default(true)
  updatedByUserId Int?
  createdAt       DateTime? @default(now()) @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([salonId, role, permissionId], map: "uq_salon_role_permission")
  @@index([salonId, role], map: "idx_salon_role_permission_salon_role")
}

model UserPermissionOverride {
  id              Int       @id @default(autoincrement())
  salonId         Int
  userId          Int
  permissionId    Int
  granted         Boolean
  reason          String?
  expiresAt       DateTime? @db.Timestamp(6)
  updatedByUserId Int?
  createdAt       DateTime? @default(now()) @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([salonId, userId, permissionId], map: "uq_user_permission_override")
  @@index([salonId, userId], map: "idx_user_permission_override_salon_user")
}

model AccessAuditLog {
  id          Int       @id @default(autoincrement())
  salonId     Int
  actorUserId Int?
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime? @default(now()) @db.Timestamp(6)

  @@index([salonId, createdAt], map: "idx_access_audit_salon_created")
}


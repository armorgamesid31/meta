generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Salon {
  id                  Int                          @id @default(autoincrement())
  name                String
  address             String?
  logoUrl             String?
  chakraPluginId      String?
  chakraPhoneNumberId String?
  city                String?
  citySlug            String?
  district            String?
  districtSlug        String?
  countryCode         String?
  tagline             String?
  about               String?
  heroImageUrl        String?
  instagramUrl        String?
  whatsappPhone       String?
  bookingMode         BookingMode?                 @default(INTERNAL)
  createdAt           DateTime?                    @default(now()) @db.Timestamp(6)
  updatedAt           DateTime?                    @default(now()) @updatedAt @db.Timestamp(6)
  slug                String?                      @unique(map: "salon_slug_unique")
  appointments        Appointment[]
  customers           Customer[]
  galleryImages       SalonGalleryImage[]
  authSessions        MobileAuthSession[]
  inventoryItems      InventoryItem[]
  campaigns           Campaign[]
  automationRules     AutomationRule[]
  analyticsPresets    AnalyticsPreset[]
  aiAgentSettings     SalonAiAgentSettings?
  blacklistEntries    BlacklistEntry[]
  settings            SalonSettings?
  testimonials        SalonTestimonial[]
  messageDispatches   AppointmentMessageDispatch[]
  messageTemplates    SalonMessageTemplate[]
  channelBindings     SalonChannelBinding[]
  inboundMessages     InboundMessageQueue[]
  conversationStates  ConversationState[]
  outboundMessages    OutboundMessageTrace[]
  users               SalonUser[]
  services            Service[]
  serviceGroups       ServiceGroup[]
  serviceRegions      ServiceRegion[]
  ServiceCategory     ServiceCategory[]
  contentItems        ContentItem[]
  staff               Staff[]

  @@index([citySlug, districtSlug], map: "idx_salon_city_district_slug")
}

model SalonSettings {
  id                  Int        @id @default(autoincrement())
  workStartHour       Int        @default(9)
  workEndHour         Int        @default(18)
  slotInterval        Int        @default(30)
  workingDays         Json?
  commonQuestions     Json?
  timezone            String     @default("Europe/Istanbul")
  contentSourceLocale LocaleCode @default(tr)
  categoryOrder       Json? // List of category keys for custom ordering
  createdAt           DateTime?  @default(now()) @db.Timestamp(6)
  updatedAt           DateTime?  @default(now()) @updatedAt @db.Timestamp(6)
  salonId             Int        @unique
  salon               Salon      @relation(fields: [salonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SalonAiAgentSettings {
  id                Int       @id @default(autoincrement())
  salonId           Int       @unique
  tone              String    @default("balanced")
  answerLength      String    @default("medium")
  emojiUsage        String    @default("low")
  bookingGuidance   String    @default("medium")
  handoverThreshold String    @default("balanced")
  aiDisclosure      String    @default("onQuestion")
  faqAnswers        Json?
  createdAt         DateTime? @default(now()) @db.Timestamp(6)
  updatedAt         DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon             Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model SalonUser {
  id                     Int                  @id @default(autoincrement())
  email                  String
  passwordHash           String
  role                   String
  createdAt              DateTime?            @default(now()) @db.Timestamp(6)
  updatedAt              DateTime?            @default(now()) @updatedAt @db.Timestamp(6)
  salonId                Int
  authSessions           MobileAuthSession[]
  publishedContentValues ContentLocaleValue[]
  salon                  Salon                @relation(fields: [salonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model MobileAuthSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  salonId          Int
  refreshTokenHash String    @unique(map: "uq_mobile_auth_refresh_token_hash")
  expiresAt        DateTime  @db.Timestamp(6)
  revokedAt        DateTime? @db.Timestamp(6)
  createdAt        DateTime? @default(now()) @db.Timestamp(6)
  updatedAt        DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  user             SalonUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  salon            Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, salonId], map: "idx_mobile_auth_user_salon")
  @@index([salonId, expiresAt], map: "idx_mobile_auth_salon_expires")
}

model Staff {
  id                Int                 @id @default(autoincrement())
  name              String
  title             String?
  bio               String?
  themeColor        String?
  profileImageUrl   String?
  phone             String?
  createdAt         DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  salonId           Int
  userId            Int?
  appointments      Appointment[]
  leaves            Leave[]
  salon             Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  StaffService      StaffService[]
  StaffWorkingHours StaffWorkingHours[]
  testimonials      SalonTestimonial[]
}

model Leave {
  id        Int       @id @default(autoincrement())
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  reason    String?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  staffId   Int
  staff     Staff     @relation(fields: [staffId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Service {
  id                 Int                  @id @default(autoincrement())
  name               String
  description        String?
  isActive           Boolean?             @default(true)
  price              Float
  duration           Int
  createdAt          DateTime?            @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?            @default(now()) @updatedAt @db.Timestamp(6)
  salonId            Int
  category           String?
  requiresSpecialist Boolean?             @default(false)
  categoryId         Int?
  regionId           Int?
  serviceGroupId     Int?
  capacityOverride   Int?
  sequentialOverride Boolean?
  bufferOverride     Int?
  appointments       Appointment[]
  ServiceCategory    ServiceCategory?     @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
  ServiceRegion      ServiceRegion?       @relation(fields: [regionId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  serviceGroup       ServiceGroup?        @relation(fields: [serviceGroupId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  salon              Salon                @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ServiceGender      ServiceGender[]
  translations       ServiceTranslation[]
  ServiceStats       ServiceStats[]
  StaffService       StaffService[]

  @@unique([name, salonId])
}

model ServiceGroup {
  id                 Int                       @id @default(autoincrement())
  salonId            Int
  name               String
  description        String?
  isActive           Boolean?                  @default(true)
  displayOrder       Int?
  capacity           Int?                      @default(1)
  sequentialRequired Boolean?                  @default(false)
  preparationMinutes Int?                      @default(0)
  createdAt          DateTime?                 @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?                 @default(now()) @updatedAt @db.Timestamp(6)
  salon              Salon                     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services           Service[]
  translations       ServiceGroupTranslation[]

  @@unique([salonId, name], map: "uq_service_group_name_per_salon")
  @@index([salonId, displayOrder], map: "idx_service_group_salon_display_order")
}

model Appointment {
  id                 Int                          @id @default(autoincrement())
  customerName       String
  customerPhone      String
  customerId         Int?
  startTime          DateTime                     @db.Timestamp(6)
  endTime            DateTime                     @db.Timestamp(6)
  status             AppointmentStatus?           @default(BOOKED)
  source             AppointmentSource?           @default(CUSTOMER)
  notes              String?
  customerRating     Int?
  customerReview     String?
  customerReviewedAt DateTime?                    @db.Timestamp(6)
  createdAt          DateTime?                    @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?                    @default(now()) @updatedAt @db.Timestamp(6)
  salonId            Int
  staffId            Int
  serviceId          Int
  gender             CustomerGender               @default(female)
  customer           Customer?                    @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messageDispatches  AppointmentMessageDispatch[]
  salon              Salon                        @relation(fields: [salonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service            Service                      @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  staff              Staff                        @relation(fields: [staffId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([salonId, startTime], map: "idx_appointment_salon_start")
  @@index([salonId, status, startTime], map: "idx_appointment_salon_status_start")
  @@index([staffId, startTime, endTime], map: "idx_staff_time")
}

model SearchContext {
  id        String   @id @default(uuid())
  salonId   Int
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model MagicLink {
  id        Int           @id @default(autoincrement())
  token     String        @unique
  phone     String
  type      MagicLinkType
  context   Json?
  expiresAt DateTime      @db.Timestamp(6)
  usedAt    DateTime?     @db.Timestamp(6)
  createdAt DateTime?     @default(now()) @db.Timestamp(6)
  updatedAt DateTime?     @default(now()) @updatedAt @db.Timestamp(6)
}

model Customer {
  id              Int             @id @default(autoincrement())
  name            String?
  phone           String
  instagram       String?
  createdAt       DateTime?       @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?       @default(now()) @updatedAt @db.Timestamp(6)
  salonId         Int
  gender          CustomerGender?
  birthDate       DateTime?       @db.Date
  acceptMarketing Boolean?        @default(false)
  appointments    Appointment[]
  salon           Salon           @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([phone, salonId])
  @@index([salonId, createdAt], map: "idx_customer_salon_created")
}

model CustomerBehaviorLog {
  id            Int       @id @default(autoincrement())
  customerId    Int
  salonId       Int
  appointmentId Int?
  action        String
  behaviorType  String?
  severityScore Float?
  metadata      Json?
  occurredAt    DateTime? @default(now()) @db.Timestamp(6)
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
}

model CustomerRiskProfile {
  id                      Int       @id @default(autoincrement())
  customerId              Int
  salonId                 Int
  riskScore               Float?    @default(0)
  riskLevel               String?
  noShowCount             Int?      @default(0)
  noShows                 Int?      @default(0)
  lastMinuteCount         Int?      @default(0)
  lastMinuteCancellations Int?      @default(0)
  totalBookings           Int?      @default(0)
  lastCalculatedAt        DateTime? @db.Timestamp(6)
  createdAt               DateTime? @default(now()) @db.Timestamp(6)
  updatedAt               DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([customerId, salonId])
}

model SalonRiskConfig {
  id                       Int       @id @default(autoincrement())
  salonId                  Int       @unique
  isEnabled                Boolean?  @default(false)
  lastMinuteHoursThreshold Int?      @default(24)
  noShowPenalty            Float?    @default(0.1)
  lastMinutePenalty        Float?    @default(0.05)
  createdAt                DateTime? @default(now()) @db.Timestamp(6)
  updatedAt                DateTime? @default(now()) @updatedAt @db.Timestamp(6)
}

model ServiceStats {
  serviceId    Int
  minPrice     Float
  maxPrice     Float
  minDuration  Int
  maxDuration  Int
  description  String?
  regionId     Int?
  regionName   String?
  calculatedAt DateTime?      @default(now()) @db.Timestamp(6)
  salonId      Int
  gender       CustomerGender @default(female)
  Service      Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([serviceId, salonId, gender])
}

model StaffService {
  id                     Int                      @id @default(autoincrement())
  staffId                Int
  serviceId              Int
  price                  Float
  duration               Int
  isactive               Boolean?                 @default(true)
  gender                 CustomerGender           @default(female)
  Service                Service                  @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Staff                  Staff                    @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  StaffServiceCustomSlot StaffServiceCustomSlot[]

  @@unique([staffId, serviceId, gender], map: "StaffService_staff_service_gender_key")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model StaffWorkingHours {
  id        Int       @id @default(autoincrement())
  staffId   Int
  dayOfWeek Int?
  startHour Int
  endHour   Int
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @db.Timestamp(6)
  Staff     Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ServiceCategory {
  id                   Int                @id @default(autoincrement())
  name                 String
  salonId              Int
  categoryId           Int?
  isActive             Boolean?           @default(true)
  marketingDescription String?
  commonQuestions      Json?
  icon                 String?
  coverImageUrl        String?
  displayOrder         Int?
  capacity             Int?               @default(1)
  sequentialRequired   Boolean?           @default(false)
  bufferMinutes        Int?               @default(0)
  createdAt            DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt            DateTime?          @default(now()) @db.Timestamp(6)
  categoryRef          Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  Service              Service[]
  ServiceRegion        ServiceRegion[]
  Salon                Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  testimonials         SalonTestimonial[]

  @@index([salonId, displayOrder], map: "idx_servicecategory_salon_display_order")
  @@index([salonId, categoryId, displayOrder], map: "idx_servicecategory_salon_category_display")
}

model ServiceRegion {
  id              Int              @id @default(autoincrement())
  salonId         Int
  name            String
  categoryId      Int?
  isActive        Boolean?         @default(true)
  displayOrder    Int?
  createdAt       DateTime?        @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?        @default(now()) @updatedAt @db.Timestamp(6)
  salon           Salon            @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Service         Service[]
  ServiceCategory ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([salonId, name], map: "uq_service_region_name_per_salon")
  @@index([salonId, displayOrder], map: "idx_service_region_salon_display_order")
  @@index([salonId, categoryId], map: "idx_service_region_salon_category")
}

model SalonGalleryImage {
  id           Int       @id @default(autoincrement())
  salonId      Int
  imageUrl     String
  altText      String?
  displayOrder Int?      @default(0)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon        Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, displayOrder], map: "idx_gallery_salon_display_order")
}

model SalonTestimonial {
  id            Int                      @id @default(autoincrement())
  salonId       Int
  expertId      Int?
  categoryId    Int?
  templateType  TestimonialTemplateType?
  generatedText String
  isGenerated   Boolean?                 @default(true)
  createdAt     DateTime?                @default(now()) @db.Timestamp(6)
  updatedAt     DateTime?                @default(now()) @updatedAt @db.Timestamp(6)
  salon         Salon                    @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  expert        Staff?                   @relation(fields: [expertId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  category      ServiceCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([salonId], map: "idx_testimonial_salon")
  @@index([expertId], map: "idx_testimonial_expert")
  @@index([categoryId], map: "idx_testimonial_category")
}

model InventoryItem {
  id           Int                 @id @default(autoincrement())
  salonId      Int
  name         String
  category     String?
  unit         String              @default("adet")
  currentStock Int                 @default(0)
  minStock     Int                 @default(0)
  price        Float?
  supplier     String?
  isActive     Boolean             @default(true)
  createdAt    DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  salon        Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  movements    InventoryMovement[]

  @@index([salonId, isActive], map: "idx_inventory_item_salon_active")
}

model InventoryMovement {
  id              Int           @id @default(autoincrement())
  salonId         Int
  inventoryItemId Int
  type            String
  quantity        Int
  reason          String?
  createdByUserId Int?
  createdAt       DateTime?     @default(now()) @db.Timestamp(6)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, inventoryItemId, createdAt], map: "idx_inventory_movement_salon_item_created")
}

model Campaign {
  id          Int       @id @default(autoincrement())
  salonId     Int
  name        String
  type        String
  description String?
  config      Json?
  isActive    Boolean   @default(true)
  startsAt    DateTime? @db.Timestamp(6)
  endsAt      DateTime? @db.Timestamp(6)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon       Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, type, isActive], map: "idx_campaign_salon_type_active")
}

model AutomationRule {
  id          Int       @id @default(autoincrement())
  salonId     Int
  key         String
  name        String
  description String?
  config      Json?
  isEnabled   Boolean   @default(false)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon       Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([salonId, key], map: "uq_automation_rule_salon_key")
  @@index([salonId, isEnabled], map: "idx_automation_rule_salon_enabled")
}

model AppointmentMessageDispatch {
  id                Int                         @id @default(autoincrement())
  salonId           Int
  appointmentId     Int
  eventType         AppointmentMessageEventType
  channel           String                      @default("WHATSAPP")
  recipientPhone    String
  templateName      String?
  providerMessageId String?
  providerPayload   Json?
  createdAt         DateTime?                   @default(now()) @db.Timestamp(6)
  salon             Salon                       @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appointment       Appointment                 @relation(fields: [appointmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([salonId, appointmentId, eventType], map: "uq_msg_dispatch_salon_appointment_event")
  @@index([salonId, createdAt], map: "idx_msg_dispatch_salon_created")
  @@index([eventType, createdAt], map: "idx_msg_dispatch_event_created")
}

model SalonMessageTemplate {
  id              Int                         @id @default(autoincrement())
  salonId         Int
  eventType       AppointmentMessageEventType
  locale          LocaleCode                  @default(tr)
  sessionText     String?
  templateName    String?
  templateContent String?
  isActive        Boolean                     @default(true)
  createdAt       DateTime?                   @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?                   @default(now()) @updatedAt @db.Timestamp(6)
  salon           Salon                       @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([salonId, eventType, locale], map: "uq_salon_message_template")
  @@index([salonId, isActive], map: "idx_salon_message_template_salon_active")
}

model AnalyticsPreset {
  id        Int       @id @default(autoincrement())
  salonId   Int
  name      String
  filters   Json?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon     Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId], map: "idx_analytics_preset_salon")
}

model BlacklistEntry {
  id          Int       @id @default(autoincrement())
  salonId     Int
  customerId  Int?
  phone       String?
  fullName    String?
  reason      String?
  isActive    Boolean   @default(true)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  createdById Int?
  salon       Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, isActive], map: "idx_blacklist_salon_active")
}

model Category {
  id                 Int               @id @default(autoincrement())
  key                String            @unique(map: "uq_category_key")
  defaultName        String
  defaultSlug        String            @unique(map: "uq_category_default_slug")
  defaultDescription String?
  defaultImageUrl    String?
  displayOrder       Int
  isActive           Boolean           @default(true)
  createdAt          DateTime?         @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?         @default(now()) @updatedAt @db.Timestamp(6)
  serviceCategories  ServiceCategory[]
}

model Translation {
  id           Int                   @id @default(autoincrement())
  entityType   TranslationEntityType
  entityId     Int
  key          String
  locale       LocaleCode
  sourceLocale LocaleCode
  text         String
  status       TranslationStatus     @default(DRAFT)
  version      Int                   @default(1)
  createdAt    DateTime?             @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?             @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([entityType, entityId, key, locale, version], map: "uq_translation_entity_key_locale_version")
  @@index([entityType, entityId, key, locale, status], map: "idx_translation_lookup")
}

model ContentItem {
  id           Int                  @id @default(autoincrement())
  surface      ContentSurface
  page         String
  section      String
  key          String
  salonId      Int?
  metadata     Json?
  createdAt    DateTime?            @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?            @default(now()) @updatedAt @db.Timestamp(6)
  localeValues ContentLocaleValue[]
  salon        Salon?               @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([surface, page, salonId], map: "idx_content_item_surface_page_salon")
  @@index([surface, page, section], map: "idx_content_item_surface_page_section")
}

model ContentLocaleValue {
  id             Int                @id @default(autoincrement())
  itemId         Int
  locale         LocaleCode
  draftValue     String
  publishedValue String?
  status         ContentValueStatus @default(DRAFT)
  version        Int                @default(1)
  publishedAt    DateTime?          @db.Timestamp(6)
  publishedBy    Int?
  createdAt      DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt      DateTime?          @default(now()) @updatedAt @db.Timestamp(6)
  item           ContentItem        @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  publisher      SalonUser?         @relation(fields: [publishedBy], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([itemId, locale], map: "uq_content_locale_value_item_locale")
  @@index([locale, status, version], map: "idx_content_locale_value_locale_status_version")
}

model ServiceTranslation {
  id           Int               @id @default(autoincrement())
  serviceId    Int
  locale       LocaleCode
  sourceLocale LocaleCode        @default(tr)
  name         String
  description  String?
  status       TranslationStatus @default(DRAFT)
  version      Int               @default(1)
  createdAt    DateTime?         @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?         @default(now()) @updatedAt @db.Timestamp(6)
  service      Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([serviceId, locale, version], map: "uq_service_translation_service_locale_version")
  @@index([serviceId, locale, status], map: "idx_service_translation_lookup")
}

model ServiceGroupTranslation {
  id             Int               @id @default(autoincrement())
  serviceGroupId Int
  locale         LocaleCode
  sourceLocale   LocaleCode        @default(tr)
  name           String
  description    String?
  status         TranslationStatus @default(DRAFT)
  version        Int               @default(1)
  createdAt      DateTime?         @default(now()) @db.Timestamp(6)
  updatedAt      DateTime?         @default(now()) @updatedAt @db.Timestamp(6)
  serviceGroup   ServiceGroup      @relation(fields: [serviceGroupId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([serviceGroupId, locale, version], map: "uq_service_group_translation_group_locale_version")
  @@index([serviceGroupId, locale, status], map: "idx_service_group_translation_lookup")
}

model SalonChannelBinding {
  id                Int         @id @default(autoincrement())
  salonId           Int
  channel           ChannelType
  externalAccountId String
  isActive          Boolean     @default(true)
  createdAt         DateTime?   @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?   @default(now()) @updatedAt @db.Timestamp(6)
  salon             Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([channel, externalAccountId], map: "uq_salon_channel_external_account")
  @@index([salonId, channel, isActive], map: "idx_salon_channel_binding_salon_channel_active")
}

model InboundMessageQueue {
  id                Int                  @id @default(autoincrement())
  salonId           Int
  channel           ChannelType
  conversationKey   String
  providerMessageId String
  externalAccountId String
  customerName      String?
  messageType       String
  text              String?
  eventTimestamp    DateTime             @db.Timestamp(6)
  rawPayload        Json
  status            InboundMessageStatus @default(PENDING)
  batchId           String?
  processedAt       DateTime?            @db.Timestamp(6)
  createdAt         DateTime?            @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?            @default(now()) @updatedAt @db.Timestamp(6)
  salon             Salon                @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([channel, providerMessageId], map: "uq_inbound_channel_provider_message")
  @@index([salonId, channel, conversationKey, status, createdAt], map: "idx_inbound_salon_conv_status_created")
  @@index([salonId, channel, conversationKey, status, eventTimestamp], map: "idx_inbound_aggregate_window")
  @@index([status, createdAt], map: "idx_inbound_status_created")
}

model ConversationState {
  id                           Int                        @id @default(autoincrement())
  salonId                      Int
  channel                      ChannelType
  conversationKey              String
  canonicalUserId              String?
  customerId                   Int?
  mode                         ConversationAutomationMode @default(AUTO)
  humanPendingSince            DateTime?                  @db.Timestamp(6)
  humanActiveUntil             DateTime?                  @db.Timestamp(6)
  lastHumanMessageAt           DateTime?                  @db.Timestamp(6)
  lastCustomerMessageAt        DateTime?                  @db.Timestamp(6)
  manualAlways                 Boolean                    @default(false)
  profileName                  String?
  notes                        String?
  createdAt                    DateTime?                  @default(now()) @db.Timestamp(6)
  updatedAt                    DateTime?                  @default(now()) @updatedAt @db.Timestamp(6)
  salon                        Salon                      @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([salonId, channel, conversationKey], map: "uq_conversation_state_salon_channel_key")
  @@index([salonId, mode, updatedAt], map: "idx_conversation_state_salon_mode_updated")
  @@index([canonicalUserId], map: "idx_conversation_state_canonical")
}

model OutboundMessageTrace {
  id                Int                   @id @default(autoincrement())
  salonId           Int
  channel           ChannelType
  conversationKey   String
  providerMessageId String
  externalAccountId String?
  canonicalUserId   String?
  customerId        Int?
  source            OutboundMessageSource
  text              String?
  sentAt            DateTime              @db.Timestamp(6)
  createdAt         DateTime?             @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?             @default(now()) @updatedAt @db.Timestamp(6)
  salon             Salon                 @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([channel, providerMessageId], map: "uq_outbound_trace_channel_provider_message")
  @@index([salonId, channel, conversationKey, sentAt], map: "idx_outbound_trace_salon_conv_sent")
  @@index([source, sentAt], map: "idx_outbound_trace_source_sent")
}

model ServiceGender {
  serviceId Int
  gender    CustomerGender
  Service   Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)


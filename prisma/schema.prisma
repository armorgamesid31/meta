generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Salon {
  id               Int                @id @default(autoincrement())
  name             String
  address          String?
  logoUrl          String?
  chakraPluginId   String?
  city             String?
  citySlug         String?
  district         String?
  districtSlug     String?
  countryCode      String?
  tagline          String?
  about            String?
  heroImageUrl     String?
  instagramUrl     String?
  whatsappPhone    String?
  bookingMode      BookingMode?       @default(INTERNAL)
  createdAt        DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt        DateTime?          @default(now()) @updatedAt @db.Timestamp(6)
  slug             String?            @unique(map: "salon_slug_unique")
  appointments     Appointment[]
  customers        Customer[]
  galleryImages    SalonGalleryImage[]
  authSessions     MobileAuthSession[]
  inventoryItems   InventoryItem[]
  campaigns        Campaign[]
  automationRules  AutomationRule[]
  analyticsPresets AnalyticsPreset[]
  aiAgentSettings SalonAiAgentSettings?
  blacklistEntries BlacklistEntry[]
  settings         SalonSettings?
  testimonials     SalonTestimonial[]
  messageDispatches AppointmentMessageDispatch[]
  messageTemplates  SalonMessageTemplate[]
  users            SalonUser[]
  services         Service[]
  serviceGroups    ServiceGroup[]
  ServiceCategory  ServiceCategory[]
  staff            Staff[]

  @@index([citySlug, districtSlug], map: "idx_salon_city_district_slug")
}

model SalonSettings {
  id            Int       @id @default(autoincrement())
  workStartHour Int       @default(9)
  workEndHour   Int       @default(18)
  slotInterval  Int       @default(30)
  workingDays   Json?
  timezone      String    @default("Europe/Istanbul")
  contentSourceLocale LocaleCode @default(tr)
  categoryOrder Json?     // List of category keys for custom ordering
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salonId       Int       @unique
  salon         Salon     @relation(fields: [salonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SalonAiAgentSettings {
  id                Int       @id @default(autoincrement())
  salonId           Int       @unique
  tone              String    @default("balanced")
  answerLength      String    @default("medium")
  emojiUsage        String    @default("low")
  bookingGuidance   String    @default("medium")
  handoverThreshold String    @default("balanced")
  aiDisclosure      String    @default("onQuestion")
  faqAnswers        Json?
  createdAt         DateTime? @default(now()) @db.Timestamp(6)
  updatedAt         DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon             Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model SalonUser {
  id           Int       @id @default(autoincrement())
  email        String
  passwordHash String
  role         String
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salonId      Int
  authSessions MobileAuthSession[]
  salon        Salon     @relation(fields: [salonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model MobileAuthSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  salonId          Int
  refreshTokenHash String    @unique(map: "uq_mobile_auth_refresh_token_hash")
  expiresAt        DateTime  @db.Timestamp(6)
  revokedAt        DateTime? @db.Timestamp(6)
  createdAt        DateTime? @default(now()) @db.Timestamp(6)
  updatedAt        DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  user             SalonUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  salon            Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, salonId], map: "idx_mobile_auth_user_salon")
  @@index([salonId, expiresAt], map: "idx_mobile_auth_salon_expires")
}

model Staff {
  id                Int               @id @default(autoincrement())
  name              String
  title             String?
  bio               String?
  profileImageUrl   String?
  phone             String?
  createdAt         DateTime?         @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?         @default(now()) @updatedAt @db.Timestamp(6)
  salonId           Int
  userId            Int?
  appointments      Appointment[]
  leaves            Leave[]
  salon             Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  StaffService      StaffService[]
  StaffWorkingHours StaffWorkingHours[]
  testimonials      SalonTestimonial[]
}

model Leave {
  id        Int       @id @default(autoincrement())
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  reason    String?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  staffId   Int
  staff     Staff     @relation(fields: [staffId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Service {
  id                 Int              @id @default(autoincrement())
  name               String
  description        String?
  price              Float
  duration           Int
  createdAt          DateTime?        @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?        @default(now()) @updatedAt @db.Timestamp(6)
  salonId            Int
  category           String?
  requiresSpecialist Boolean?         @default(false)
  categoryId         Int?
  serviceGroupId     Int?
  capacityOverride   Int?
  sequentialOverride Boolean?
  bufferOverride     Int?
  appointments       Appointment[]
  ServiceCategory    ServiceCategory? @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
  serviceGroup       ServiceGroup?    @relation(fields: [serviceGroupId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  salon              Salon            @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ServiceGender      ServiceGender[]
  ServiceStats       ServiceStats[]
  StaffService       StaffService[]

  @@unique([name, salonId])
}

model ServiceGroup {
  id                Int       @id @default(autoincrement())
  salonId           Int
  name              String
  description       String?
  displayOrder      Int?
  capacity          Int?      @default(1)
  sequentialRequired Boolean? @default(false)
  preparationMinutes Int?     @default(0)
  createdAt         DateTime? @default(now()) @db.Timestamp(6)
  updatedAt         DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon             Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services          Service[]

  @@index([salonId, displayOrder], map: "idx_service_group_salon_display_order")
  @@unique([salonId, name], map: "uq_service_group_name_per_salon")
}

model Appointment {
  id            Int                @id @default(autoincrement())
  customerName  String
  customerPhone String
  customerId    Int?
  startTime     DateTime           @db.Timestamp(6)
  endTime       DateTime           @db.Timestamp(6)
  status        AppointmentStatus? @default(BOOKED)
  source        AppointmentSource? @default(CUSTOMER)
  notes         String?
  createdAt     DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt     DateTime?          @default(now()) @updatedAt @db.Timestamp(6)
  salonId       Int
  staffId       Int
  serviceId     Int
  gender        CustomerGender     @default(female)
  customer      Customer?          @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messageDispatches AppointmentMessageDispatch[]
  salon         Salon              @relation(fields: [salonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service       Service            @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  staff         Staff              @relation(fields: [staffId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([staffId, startTime, endTime], map: "idx_staff_time")
}

model SearchContext {
  id        String   @id @default(uuid())
  salonId   Int
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model MagicLink {
  id        Int           @id @default(autoincrement())
  token     String        @unique
  phone     String
  type      MagicLinkType
  context   Json?
  expiresAt DateTime      @db.Timestamp(6)
  usedAt    DateTime?     @db.Timestamp(6)
  createdAt DateTime?     @default(now()) @db.Timestamp(6)
  updatedAt DateTime?     @default(now()) @updatedAt @db.Timestamp(6)
}

model Customer {
  id              Int             @id @default(autoincrement())
  name            String?
  phone           String
  createdAt       DateTime?       @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?       @default(now()) @updatedAt @db.Timestamp(6)
  salonId         Int
  gender          CustomerGender?
  birthDate       DateTime?       @db.Date
  acceptMarketing Boolean?        @default(false)
  appointments    Appointment[]
  salon           Salon           @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([phone, salonId])
}

model CustomerBehaviorLog {
  id            Int       @id @default(autoincrement())
  customerId    Int
  salonId       Int
  appointmentId Int?
  action        String
  behaviorType  String?
  severityScore Float?
  metadata      Json?
  occurredAt    DateTime? @default(now()) @db.Timestamp(6)
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
}

model CustomerRiskProfile {
  id                      Int       @id @default(autoincrement())
  customerId              Int
  salonId                 Int
  riskScore               Float?    @default(0)
  riskLevel               String?
  noShowCount             Int?      @default(0)
  noShows                 Int?      @default(0)
  lastMinuteCount         Int?      @default(0)
  lastMinuteCancellations Int?      @default(0)
  totalBookings           Int?      @default(0)
  lastCalculatedAt        DateTime? @db.Timestamp(6)
  createdAt               DateTime? @default(now()) @db.Timestamp(6)
  updatedAt               DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([customerId, salonId])
}

model SalonRiskConfig {
  id                       Int       @id @default(autoincrement())
  salonId                  Int       @unique
  isEnabled                Boolean?  @default(false)
  lastMinuteHoursThreshold Int?      @default(24)
  noShowPenalty            Float?    @default(0.1)
  lastMinutePenalty        Float?    @default(0.05)
  createdAt                DateTime? @default(now()) @db.Timestamp(6)
  updatedAt                DateTime? @default(now()) @updatedAt @db.Timestamp(6)
}

model ServiceStats {
  serviceId    Int
  minPrice     Float
  maxPrice     Float
  minDuration  Int
  maxDuration  Int
  calculatedAt DateTime?      @default(now()) @db.Timestamp(6)
  salonId      Int
  gender       CustomerGender @default(female)
  Service      Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([serviceId, salonId, gender])
}

model StaffService {
  id                     Int                      @id @default(autoincrement())
  staffId                Int
  serviceId              Int
  price                  Float
  duration               Int
  isactive               Boolean?                 @default(true)
  gender                 CustomerGender           @default(female)
  Service                Service                  @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Staff                  Staff                    @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  StaffServiceCustomSlot StaffServiceCustomSlot[]

  @@unique([staffId, serviceId, gender], map: "StaffService_staff_service_gender_key")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model StaffWorkingHours {
  id        Int       @id @default(autoincrement())
  staffId   Int
  dayOfWeek Int?
  startHour Int
  endHour   Int
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @db.Timestamp(6)
  Staff     Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ServiceCategory {
  id                   Int               @id @default(autoincrement())
  name                 String
  salonId              Int
  categoryId           Int?
  marketingDescription String?
  icon                 String?
  coverImageUrl        String?
  displayOrder         Int?
  capacity             Int?              @default(1)
  sequentialRequired   Boolean?          @default(false)
  bufferMinutes        Int?              @default(0)
  createdAt            DateTime?         @default(now()) @db.Timestamp(6)
  updatedAt            DateTime?         @default(now()) @db.Timestamp(6)
  categoryRef          Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  Service              Service[]
  Salon                Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  testimonials         SalonTestimonial[]

  @@index([salonId, displayOrder], map: "idx_servicecategory_salon_display_order")
  @@index([salonId, categoryId, displayOrder], map: "idx_servicecategory_salon_category_display")
}

model SalonGalleryImage {
  id           Int       @id @default(autoincrement())
  salonId      Int
  imageUrl     String
  altText      String?
  displayOrder Int?      @default(0)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon        Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, displayOrder], map: "idx_gallery_salon_display_order")
}

model SalonTestimonial {
  id           Int                   @id @default(autoincrement())
  salonId      Int
  expertId     Int?
  categoryId   Int?
  templateType TestimonialTemplateType?
  generatedText String
  isGenerated  Boolean?              @default(true)
  createdAt    DateTime?             @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?             @default(now()) @updatedAt @db.Timestamp(6)
  salon        Salon                 @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  expert       Staff?                @relation(fields: [expertId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  category     ServiceCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([salonId], map: "idx_testimonial_salon")
  @@index([expertId], map: "idx_testimonial_expert")
  @@index([categoryId], map: "idx_testimonial_category")
}

model InventoryItem {
  id           Int                 @id @default(autoincrement())
  salonId      Int
  name         String
  category     String?
  unit         String              @default("adet")
  currentStock Int                 @default(0)
  minStock     Int                 @default(0)
  price        Float?
  supplier     String?
  isActive     Boolean             @default(true)
  createdAt    DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  salon        Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  movements    InventoryMovement[]

  @@index([salonId, isActive], map: "idx_inventory_item_salon_active")
}

model InventoryMovement {
  id              Int            @id @default(autoincrement())
  salonId         Int
  inventoryItemId Int
  type            String
  quantity        Int
  reason          String?
  createdByUserId Int?
  createdAt       DateTime?      @default(now()) @db.Timestamp(6)
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, inventoryItemId, createdAt], map: "idx_inventory_movement_salon_item_created")
}

model Campaign {
  id          Int       @id @default(autoincrement())
  salonId     Int
  name        String
  type        String
  description String?
  config      Json?
  isActive    Boolean   @default(true)
  startsAt    DateTime? @db.Timestamp(6)
  endsAt      DateTime? @db.Timestamp(6)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon       Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, type, isActive], map: "idx_campaign_salon_type_active")
}

model AutomationRule {
  id          Int       @id @default(autoincrement())
  salonId     Int
  key         String
  name        String
  description String?
  config      Json?
  isEnabled   Boolean   @default(false)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon       Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([salonId, key], map: "uq_automation_rule_salon_key")
  @@index([salonId, isEnabled], map: "idx_automation_rule_salon_enabled")
}

model AppointmentMessageDispatch {
  id                Int                          @id @default(autoincrement())
  salonId           Int
  appointmentId     Int
  eventType         AppointmentMessageEventType
  channel           String                       @default("WHATSAPP")
  recipientPhone    String
  templateName      String?
  providerMessageId String?
  providerPayload   Json?
  createdAt         DateTime?                    @default(now()) @db.Timestamp(6)
  salon             Salon                        @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appointment       Appointment                  @relation(fields: [appointmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([salonId, appointmentId, eventType], map: "uq_msg_dispatch_salon_appointment_event")
  @@index([salonId, createdAt], map: "idx_msg_dispatch_salon_created")
  @@index([eventType, createdAt], map: "idx_msg_dispatch_event_created")
}

model SalonMessageTemplate {
  id              Int                         @id @default(autoincrement())
  salonId         Int
  eventType       AppointmentMessageEventType
  locale          LocaleCode                  @default(tr)
  sessionText     String?
  templateName    String?
  templateContent String?
  isActive        Boolean                     @default(true)
  createdAt       DateTime?                   @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?                   @default(now()) @updatedAt @db.Timestamp(6)
  salon           Salon                       @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([salonId, eventType, locale], map: "uq_salon_message_template")
  @@index([salonId, isActive], map: "idx_salon_message_template_salon_active")
}

model AnalyticsPreset {
  id        Int       @id @default(autoincrement())
  salonId   Int
  name      String
  filters   Json?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon     Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId], map: "idx_analytics_preset_salon")
}

model BlacklistEntry {
  id          Int       @id @default(autoincrement())
  salonId     Int
  customerId  Int?
  phone       String?
  fullName    String?
  reason      String?
  isActive    Boolean   @default(true)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  createdById Int?
  salon       Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, isActive], map: "idx_blacklist_salon_active")
}

model Category {
  id                 Int               @id @default(autoincrement())
  key                String            @unique(map: "uq_category_key")
  defaultName        String
  defaultSlug        String            @unique(map: "uq_category_default_slug")
  defaultDescription String?
  defaultImageUrl    String?
  displayOrder       Int
  isActive           Boolean           @default(true)
  createdAt          DateTime?         @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?         @default(now()) @updatedAt @db.Timestamp(6)
  serviceCategories  ServiceCategory[]
}

model Translation {
  id           Int                   @id @default(autoincrement())
  entityType   TranslationEntityType
  entityId     Int
  key          String
  locale       LocaleCode
  sourceLocale LocaleCode
  text         String
  status       TranslationStatus     @default(DRAFT)
  version      Int                   @default(1)
  createdAt    DateTime?             @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?             @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([entityType, entityId, key, locale, version], map: "uq_translation_entity_key_locale_version")
  @@index([entityType, entityId, key, locale, status], map: "idx_translation_lookup")
}

model ServiceGender {
  serviceId Int
  gender    CustomerGender
  Service   Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([serviceId, gender])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model StaffServiceCustomSlot {
  id             Int          @id @default(autoincrement())
  staffServiceId Int
  dayOfWeek      Int
  startTime      DateTime     @db.Time(6)
  createdAt      DateTime?    @default(now()) @db.Timestamp(6)
  StaffService   StaffService @relation(fields: [staffServiceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_staffservice")
}

enum UserRole {
  OWNER
  STAFF
  MANAGER
  RECEPTION
  FINANCE
}

enum AppointmentStatus {
  BOOKED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum AppointmentSource {
  CUSTOMER
  ADMIN
  AUTOMATION
}

enum AppointmentMessageEventType {
  CONFIRMATION
  REMINDER
  CANCELLATION
  SATISFACTION_SURVEY
}

enum CustomerGender {
  male
  female
  other
}

enum MagicLinkType {
  BOOKING
  RESCHEDULE
}

enum BookingMode {
  INTERNAL
  WHATSAPP
}

enum TestimonialTemplateType {
  CATEGORY_EXPERT
  EXPERT_ONLY
  CATEGORY_ONLY
  GENERIC
}

enum LocaleCode {
  tr
  en
  es
  fr
  de
  pt
  ru
  zh
  ar
  hi
}

enum TranslationEntityType {
  SALON
  CATEGORY
  EXPERT
  TEMPLATE
  UI
}

enum TranslationStatus {
  DRAFT
  REVIEWED
  APPROVED
}

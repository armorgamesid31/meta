generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Salon {
  id                  Int                          @id @default(autoincrement())
  name                String
  address             String?
  logoUrl             String?
  chakraPluginId      String?
  chakraPhoneNumberId String?
  city                String?
  citySlug            String?
  district            String?
  districtSlug        String?
  countryCode         String?
  tagline             String?
  about               String?
  heroImageUrl        String?
  instagramUrl        String?
  whatsappPhone       String?
  bookingMode         BookingMode?                 @default(INTERNAL)
  createdAt           DateTime?                    @default(now()) @db.Timestamp(6)
  updatedAt           DateTime?                    @default(now()) @updatedAt @db.Timestamp(6)
  slug                String?                      @unique(map: "salon_slug_unique")
  appointments        Appointment[]
  customers           Customer[]
  galleryImages       SalonGalleryImage[]
  authSessions        MobileAuthSession[]
  inventoryItems      InventoryItem[]
  campaigns           Campaign[]
  campaignApplications AppointmentCampaignApplication[]
  campaignWallets     CustomerCampaignWallet[]
  campaignEnrollments CustomerCampaignEnrollment[]
  campaignShareLinks  CampaignShareLink[]
  campaignAttributions CampaignAttribution[]
  automationRules     AutomationRule[]
  packageTemplates    PackageTemplate[]
  customerPackages    CustomerPackage[]
  packageLedgers      PackageLedger[]
  packageConsumptions AppointmentPackageConsumption[]
  analyticsPresets    AnalyticsPreset[]
  aiAgentSettings     SalonAiAgentSettings?
  blacklistEntries    BlacklistEntry[]
  settings            SalonSettings?
  waitlistEntries     WaitlistEntry[]
  waitlistOffers      WaitlistOffer[]
  testimonials        SalonTestimonial[]
  messageDispatches   AppointmentMessageDispatch[]
  messageTemplates    SalonMessageTemplate[]
  channelBindings     SalonChannelBinding[]
  inboundMessages     InboundMessageQueue[]
  conversationEvents  ConversationMessageEvent[]
  conversationStates  ConversationState[]
  outboundMessages    OutboundMessageTrace[]
  channelProfiles     ChannelProfileCache[]
  magicLinks          MagicLink[]
  identitySessions    IdentitySession[]
  identityBindings    IdentityBinding[]
  users               SalonUser[]
  services            Service[]
  serviceGroups       ServiceGroup[]
  serviceRegions      ServiceRegion[]
  ServiceCategory     ServiceCategory[]
  contentItems        ContentItem[]
  staff               Staff[]

  @@index([citySlug, districtSlug], map: "idx_salon_city_district_slug")
}

model SalonSettings {
  id                  Int        @id @default(autoincrement())
  workStartHour       Int        @default(9)
  workEndHour         Int        @default(18)
  slotInterval        Int        @default(30)
  workingDays         Json?
  commonQuestions     Json?
  timezone            String     @default("Europe/Istanbul")
  contentSourceLocale LocaleCode @default(tr)
  categoryOrder       Json? // List of category keys for custom ordering
  createdAt           DateTime?  @default(now()) @db.Timestamp(6)
  updatedAt           DateTime?  @default(now()) @updatedAt @db.Timestamp(6)
  salonId             Int        @unique
  salon               Salon      @relation(fields: [salonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SalonAiAgentSettings {
  id                Int       @id @default(autoincrement())
  salonId           Int       @unique
  tone              String    @default("balanced")
  answerLength      String    @default("medium")
  emojiUsage        String    @default("low")
  bookingGuidance   String    @default("medium")
  handoverThreshold String    @default("balanced")
  aiDisclosure      String    @default("onQuestion")
  faqAnswers        Json?
  createdAt         DateTime? @default(now()) @db.Timestamp(6)
  updatedAt         DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon             Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model SalonUser {
  id                     Int                  @id @default(autoincrement())
  email                  String
  displayName            String?
  passwordHash           String
  role                   String
  isActive               Boolean              @default(true)
  passwordResetRequired  Boolean              @default(false)
  lastLoginAt            DateTime?            @db.Timestamp(6)
  createdAt              DateTime?            @default(now()) @db.Timestamp(6)
  updatedAt              DateTime?            @default(now()) @updatedAt @db.Timestamp(6)
  salonId                Int
  authSessions           MobileAuthSession[]
  publishedContentValues ContentLocaleValue[]
  salon                  Salon                @relation(fields: [salonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model MobileAuthSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  salonId          Int
  refreshTokenHash String    @unique(map: "uq_mobile_auth_refresh_token_hash")
  expiresAt        DateTime  @db.Timestamp(6)
  revokedAt        DateTime? @db.Timestamp(6)
  createdAt        DateTime? @default(now()) @db.Timestamp(6)
  updatedAt        DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  user             SalonUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  salon            Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, salonId], map: "idx_mobile_auth_user_salon")
  @@index([salonId, expiresAt], map: "idx_mobile_auth_salon_expires")
}

model Staff {
  id                Int                 @id @default(autoincrement())
  name              String
  title             String?
  bio               String?
  themeColor        String?
  profileImageUrl   String?
  phone             String?
  createdAt         DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  salonId           Int
  userId            Int?
  appointments      Appointment[]
  leaves            Leave[]
  salon             Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  StaffService      StaffService[]
  StaffWorkingHours StaffWorkingHours[]
  testimonials      SalonTestimonial[]
}

model Leave {
  id        Int       @id @default(autoincrement())
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  reason    String?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  staffId   Int
  staff     Staff     @relation(fields: [staffId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Service {
  id                 Int                  @id @default(autoincrement())
  name               String
  description        String?
  isActive           Boolean?             @default(true)
  price              Float
  duration           Int
  createdAt          DateTime?            @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?            @default(now()) @updatedAt @db.Timestamp(6)
  salonId            Int
  category           String?
  requiresSpecialist Boolean?             @default(false)
  categoryId         Int?
  regionId           Int?
  serviceGroupId     Int?
  capacityOverride   Int?
  sequentialOverride Boolean?
  bufferOverride     Int?
  appointments       Appointment[]
  ServiceCategory    ServiceCategory?     @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
  ServiceRegion      ServiceRegion?       @relation(fields: [regionId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  serviceGroup       ServiceGroup?        @relation(fields: [serviceGroupId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  salon              Salon                @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ServiceGender      ServiceGender[]
  translations       ServiceTranslation[]
  templateServices   PackageTemplateService[]
  packageBalances    CustomerPackageServiceBalance[]
  packageLedgers     PackageLedger[]
  packageConsumptions AppointmentPackageConsumption[]
  campaignApplications AppointmentCampaignApplication[]
  ServiceStats       ServiceStats[]
  StaffService       StaffService[]

  @@unique([name, salonId])
}

model ServiceGroup {
  id                 Int                       @id @default(autoincrement())
  salonId            Int
  name               String
  description        String?
  isActive           Boolean?                  @default(true)
  displayOrder       Int?
  capacity           Int?                      @default(1)
  sequentialRequired Boolean?                  @default(false)
  preparationMinutes Int?                      @default(0)
  createdAt          DateTime?                 @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?                 @default(now()) @updatedAt @db.Timestamp(6)
  salon              Salon                     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services           Service[]
  translations       ServiceGroupTranslation[]

  @@unique([salonId, name], map: "uq_service_group_name_per_salon")
  @@index([salonId, displayOrder], map: "idx_service_group_salon_display_order")
}

model Appointment {
  id                 Int                          @id @default(autoincrement())
  customerName       String
  customerPhone      String
  customerId         Int?
  startTime          DateTime                     @db.Timestamp(6)
  endTime            DateTime                     @db.Timestamp(6)
  status             AppointmentStatus?           @default(BOOKED)
  source             AppointmentSource?           @default(CUSTOMER)
  notes              String?
  paymentMethod      PaymentMethod?
  paymentRecordedAt  DateTime?                    @db.Timestamp(6)
  listPrice          Float?
  discountTotal      Float?
  finalPrice         Float?
  campaignSnapshot   Json?
  customerRating     Int?
  customerReview     String?
  customerReviewedAt DateTime?                    @db.Timestamp(6)
  preferenceMode     AppointmentPreferenceMode?   @default(ANY)
  preferredStaffId   Int?
  rescheduledFromAppointmentId Int?
  rescheduleBatchId  String?
  createdAt          DateTime?                    @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?                    @default(now()) @updatedAt @db.Timestamp(6)
  salonId            Int
  staffId            Int
  serviceId          Int
  gender             CustomerGender               @default(female)
  customer           Customer?                    @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messageDispatches  AppointmentMessageDispatch[]
  packageConsumptions AppointmentPackageConsumption[]
  campaignApplications AppointmentCampaignApplication[]
  campaignAttributions CampaignAttribution[] @relation("CampaignAttributionFirstAppointment")
  salon              Salon                        @relation(fields: [salonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service            Service                      @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  staff              Staff                        @relation(fields: [staffId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([salonId, startTime], map: "idx_appointment_salon_start")
  @@index([salonId, status, startTime], map: "idx_appointment_salon_status_start")
  @@index([staffId, startTime, endTime], map: "idx_staff_time")
  @@index([salonId, rescheduleBatchId], map: "idx_appointment_salon_reschedule_batch")
  @@index([rescheduledFromAppointmentId], map: "idx_appointment_rescheduled_from")
}

model SearchContext {
  id        String   @id @default(uuid())
  salonId   Int
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model MagicLink {
  id                Int                 @id @default(autoincrement())
  token             String              @unique
  phone             String
  type              MagicLinkType
  context           Json?
  salonId           Int
  channel           ChannelType
  subjectType       IdentitySubjectType
  subjectNormalized String
  status            MagicLinkStatus     @default(ACTIVE)
  identitySessionId String
  usedByCustomerId  Int?
  expiresAt         DateTime            @db.Timestamp(6)
  usedAt            DateTime?           @db.Timestamp(6)
  createdAt         DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  identitySession   IdentitySession     @relation(fields: [identitySessionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  salon             Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usedByCustomer    Customer?           @relation("MagicLinkUsedByCustomer", fields: [usedByCustomerId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([salonId, channel, subjectNormalized, status], map: "idx_magiclink_lookup")
  @@index([identitySessionId, createdAt], map: "idx_magiclink_session_created")
  @@index([salonId, status, expiresAt], map: "idx_magiclink_salon_status_exp")
}

model IdentitySession {
  id                String                @id @default(uuid())
  salonId           Int
  channel           ChannelType
  subjectType       IdentitySubjectType
  subjectRaw        String
  subjectNormalized String
  conversationKey   String?
  canonicalUserId   String?
  customerId        Int?
  status            IdentitySessionStatus @default(ACTIVE)
  lastInboundAt     DateTime?             @db.Timestamp(6)
  lastOutboundAt    DateTime?             @db.Timestamp(6)
  metadata          Json?
  createdAt         DateTime?             @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?             @default(now()) @updatedAt @db.Timestamp(6)
  bindings          IdentityBinding[]
  customer          Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  magicLinks        MagicLink[]
  salon             Salon                 @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([salonId, channel, subjectNormalized], map: "uq_identity_session_subject")
  @@index([salonId, conversationKey], map: "idx_identity_session_conv")
  @@index([canonicalUserId], map: "idx_identity_session_canonical")
}

model IdentityBinding {
  id                Int                   @id @default(autoincrement())
  salonId           Int
  channel           ChannelType
  subjectNormalized String
  subjectRaw        String
  customerId        Int
  sessionId         String?
  source            IdentityBindingSource @default(SYSTEM)
  verifiedAt        DateTime?             @default(now()) @db.Timestamp(6)
  isActive          Boolean               @default(true)
  createdAt         DateTime?             @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?             @default(now()) @updatedAt @db.Timestamp(6)
  customer          Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  salon             Salon                 @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  session           IdentitySession?      @relation(fields: [sessionId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([salonId, channel, subjectNormalized], map: "uq_identity_binding_subject")
  @@index([customerId, salonId], map: "idx_identity_binding_customer_salon")
  @@index([salonId, channel, isActive], map: "idx_identity_binding_salon_channel_active")
}

model Customer {
  id                 Int                        @id @default(autoincrement())
  name               String?
  phone              String
  instagram          String?
  createdAt          DateTime?                  @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?                  @default(now()) @updatedAt @db.Timestamp(6)
  salonId            Int
  gender             CustomerGender?
  birthDate          DateTime?                  @db.Date
  acceptMarketing    Boolean?                   @default(false)
  registrationStatus CustomerRegistrationStatus @default(VERIFIED)
  appointments       Appointment[]
  packages           CustomerPackage[]
  packageLedgers     PackageLedger[]
  packageConsumptions AppointmentPackageConsumption[]
  campaignApplications AppointmentCampaignApplication[]
  campaignWallets      CustomerCampaignWallet[]
  campaignEnrollments  CustomerCampaignEnrollment[]
  campaignShareLinks   CampaignShareLink[]
  referrerAttributions CampaignAttribution[] @relation("CampaignAttributionReferrerCustomer")
  referredAttributions CampaignAttribution[] @relation("CampaignAttributionReferredCustomer")
  identityBindings   IdentityBinding[]
  identitySessions   IdentitySession[]
  salon              Salon                      @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usedMagicLinks     MagicLink[]                @relation("MagicLinkUsedByCustomer")
  waitlistEntries    WaitlistEntry[]

  @@unique([phone, salonId])
  @@index([salonId, createdAt], map: "idx_customer_salon_created")
}

model CustomerBehaviorLog {
  id            Int       @id @default(autoincrement())
  customerId    Int
  salonId       Int
  appointmentId Int?
  action        String
  behaviorType  String?
  severityScore Float?
  metadata      Json?
  occurredAt    DateTime? @default(now()) @db.Timestamp(6)
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
}

model CustomerRiskProfile {
  id                      Int       @id @default(autoincrement())
  customerId              Int
  salonId                 Int
  riskScore               Float?    @default(0)
  riskLevel               String?
  noShowCount             Int?      @default(0)
  noShows                 Int?      @default(0)
  lastMinuteCount         Int?      @default(0)
  lastMinuteCancellations Int?      @default(0)
  totalBookings           Int?      @default(0)
  lastCalculatedAt        DateTime? @db.Timestamp(6)
  createdAt               DateTime? @default(now()) @db.Timestamp(6)
  updatedAt               DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([customerId, salonId])
}

model SalonRiskConfig {
  id                       Int       @id @default(autoincrement())
  salonId                  Int       @unique
  isEnabled                Boolean?  @default(false)
  lastMinuteHoursThreshold Int?      @default(24)
  noShowPenalty            Float?    @default(0.1)
  lastMinutePenalty        Float?    @default(0.05)
  createdAt                DateTime? @default(now()) @db.Timestamp(6)
  updatedAt                DateTime? @default(now()) @updatedAt @db.Timestamp(6)
}

model ServiceStats {
  serviceId    Int
  minPrice     Float
  maxPrice     Float
  minDuration  Int
  maxDuration  Int
  description  String?
  regionId     Int?
  regionName   String?
  calculatedAt DateTime?      @default(now()) @db.Timestamp(6)
  salonId      Int
  gender       CustomerGender @default(female)
  Service      Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([serviceId, salonId, gender])
}

model StaffService {
  id                     Int                      @id @default(autoincrement())
  staffId                Int
  serviceId              Int
  price                  Float
  duration               Int
  isactive               Boolean?                 @default(true)
  gender                 CustomerGender           @default(female)
  Service                Service                  @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Staff                  Staff                    @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  StaffServiceCustomSlot StaffServiceCustomSlot[]

  @@unique([staffId, serviceId, gender], map: "StaffService_staff_service_gender_key")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model StaffWorkingHours {
  id        Int       @id @default(autoincrement())
  staffId   Int
  dayOfWeek Int?
  startHour Int
  endHour   Int
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @db.Timestamp(6)
  Staff     Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ServiceCategory {
  id                   Int                @id @default(autoincrement())
  name                 String
  salonId              Int
  categoryId           Int?
  isActive             Boolean?           @default(true)
  marketingDescription String?
  commonQuestions      Json?
  icon                 String?
  coverImageUrl        String?
  displayOrder         Int?
  capacity             Int?               @default(1)
  sequentialRequired   Boolean?           @default(false)
  bufferMinutes        Int?               @default(0)
  createdAt            DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt            DateTime?          @default(now()) @db.Timestamp(6)
  categoryRef          Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  Service              Service[]
  ServiceRegion        ServiceRegion[]
  Salon                Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  testimonials         SalonTestimonial[]

  @@index([salonId, displayOrder], map: "idx_servicecategory_salon_display_order")
  @@index([salonId, categoryId, displayOrder], map: "idx_servicecategory_salon_category_display")
}

model ServiceRegion {
  id              Int              @id @default(autoincrement())
  salonId         Int
  name            String
  categoryId      Int?
  isActive        Boolean?         @default(true)
  displayOrder    Int?
  createdAt       DateTime?        @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?        @default(now()) @updatedAt @db.Timestamp(6)
  salon           Salon            @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Service         Service[]
  ServiceCategory ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([salonId, name], map: "uq_service_region_name_per_salon")
  @@index([salonId, displayOrder], map: "idx_service_region_salon_display_order")
  @@index([salonId, categoryId], map: "idx_service_region_salon_category")
}

model SalonGalleryImage {
  id           Int       @id @default(autoincrement())
  salonId      Int
  imageUrl     String
  altText      String?
  displayOrder Int?      @default(0)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon        Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, displayOrder], map: "idx_gallery_salon_display_order")
}

model SalonTestimonial {
  id            Int                      @id @default(autoincrement())
  salonId       Int
  expertId      Int?
  categoryId    Int?
  templateType  TestimonialTemplateType?
  generatedText String
  isGenerated   Boolean?                 @default(true)
  createdAt     DateTime?                @default(now()) @db.Timestamp(6)
  updatedAt     DateTime?                @default(now()) @updatedAt @db.Timestamp(6)
  salon         Salon                    @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  expert        Staff?                   @relation(fields: [expertId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  category      ServiceCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([salonId], map: "idx_testimonial_salon")
  @@index([expertId], map: "idx_testimonial_expert")
  @@index([categoryId], map: "idx_testimonial_category")
}

model InventoryItem {
  id           Int                 @id @default(autoincrement())
  salonId      Int
  name         String
  category     String?
  unit         String              @default("adet")
  currentStock Int                 @default(0)
  minStock     Int                 @default(0)
  price        Float?
  supplier     String?
  isActive     Boolean             @default(true)
  createdAt    DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  salon        Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  movements    InventoryMovement[]

  @@index([salonId, isActive], map: "idx_inventory_item_salon_active")
}

model InventoryMovement {
  id              Int           @id @default(autoincrement())
  salonId         Int
  inventoryItemId Int
  type            String
  quantity        Int
  reason          String?
  createdByUserId Int?
  createdAt       DateTime?     @default(now()) @db.Timestamp(6)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([salonId, inventoryItemId, createdAt], map: "idx_inventory_movement_salon_item_created")
}

model Campaign {
  id          Int       @id @default(autoincrement())
  salonId     Int
  name        String
  type        String
  description String?
  config      Json?
  priority    Int       @default(100)
  deliveryMode CampaignDeliveryMode @default(MANUAL)
  maxGlobalUsage Int?
  maxPerCustomer Int?
  isActive    Boolean   @default(true)
  publishedAt DateTime? @db.Timestamp(6)
  startsAt    DateTime? @db.Timestamp(6)
  endsAt      DateTime? @db.Timestamp(6)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon       Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  applications AppointmentCampaignApplication[]
  wallets     CustomerCampaignWallet[]
  enrollments CustomerCampaignEnrollment[]
  shareLinks  CampaignShareLink[]
  attributions CampaignAttribution[]

  @@index([salonId, type, isActive], map: "idx_campaign_salon_type_active")
  @@index([salonId, priority, isActive], map: "idx_campaign_salon_priority_active")
}

model AppointmentCampaignApplication {
  id            Int       @id @default(autoincrement())
  salonId       Int
  appointmentId Int
  customerId    Int?
  campaignId    Int
  serviceId     Int?
  status        CampaignApplicationStatus @default(APPLIED)
  listPrice     Float
  discountAmount Float
  finalPrice    Float
  metadata      Json?
  appliedAt     DateTime? @default(now()) @db.Timestamp(6)
  releasedAt    DateTime? @db.Timestamp(6)
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  salon         Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service       Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([salonId, appointmentId], map: "idx_campaign_app_salon_appointment")

    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "id": "trigger_hourly",
      "name": "Hourly Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [200, 400]
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH eligible AS (\n  SELECT a.id AS \"appointmentId\", a.\"customerId\", a.\"salonId\"\n  FROM \"Appointment\" a\n  WHERE a.status = 'BOOKED'\n    AND a.\"customerId\" IS NOT NULL\n    AND a.\"startTime\" > NOW() + INTERVAL '23 hours'\n    AND a.\"startTime\" < NOW() + INTERVAL '25 hours'\n    AND NOT EXISTS (\n      SELECT 1 FROM \"NotificationLog\" nl\n      WHERE nl.\"appointmentId\" = a.id AND nl.type = 'REMINDER_1_DAY'\n    )\n)\nSELECT * FROM eligible LIMIT 500;"
      },
      "id": "q_reminder_1d",
      "name": "Query: 1-day reminders due",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [500, 100],
      "credentials": {
        "postgres": {
          "id": "kedy_postgres",
          "name": "Kedy Postgres"
        }
      }
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH eligible AS (\n  SELECT a.id AS \"appointmentId\", a.\"customerId\", a.\"salonId\"\n  FROM \"Appointment\" a\n  WHERE a.status = 'BOOKED'\n    AND a.\"customerId\" IS NOT NULL\n    AND a.\"startTime\" > NOW() + INTERVAL '71 hours'\n    AND a.\"startTime\" < NOW() + INTERVAL '73 hours'\n    AND NOT EXISTS (\n      SELECT 1 FROM \"NotificationLog\" nl\n      WHERE nl.\"appointmentId\" = a.id AND nl.type = 'REMINDER_3_DAY'\n    )\n)\nSELECT * FROM eligible LIMIT 500;"
      },
      "id": "q_reminder_3d",
      "name": "Query: 3-day reminders due",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,

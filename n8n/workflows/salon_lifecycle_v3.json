    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH eligible AS (\n  SELECT a.id AS \"appointmentId\", a.\"customerId\", a.\"salonId\"\n  FROM \"Appointment\" a\n  WHERE a.\"customerId\" IS NOT NULL\n    AND a.status = 'NO_SHOW'\n    AND a.\"endTime\" > NOW() - INTERVAL '2 hours'\n    AND a.\"endTime\" < NOW()\n    AND NOT EXISTS (\n      SELECT 1 FROM \"NotificationLog\" nl\n      WHERE nl.\"appointmentId\" = a.id AND nl.type = 'NO_SHOW'\n    )\n)\nSELECT * FROM eligible LIMIT 500;"
      },
      "id": "q_no_show",
      "name": "Query: no-show notifications",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [500, 550],

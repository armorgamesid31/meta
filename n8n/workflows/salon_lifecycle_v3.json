      }
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH eligible AS (\n  SELECT a.id AS \"appointmentId\", a.\"customerId\", a.\"salonId\"\n  FROM \"Appointment\" a\n  WHERE a.status = 'BOOKED'\n    AND a.\"customerId\" IS NOT NULL\n    AND a.\"startTime\" > NOW() + INTERVAL '1 hour 30 minutes'\n    AND a.\"startTime\" < NOW() + INTERVAL '2 hours 30 minutes'\n    AND NOT EXISTS (\n      SELECT 1 FROM \"NotificationLog\" nl\n      WHERE nl.\"appointmentId\" = a.id AND nl.type = 'REMINDER_2_HOUR'\n    )\n)\nSELECT * FROM eligible LIMIT 500;"
      },
      "id": "q_reminder_2h",
      "name": "Query: 2-hour reminders due",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [500, 400],
      "credentials": {
        "postgres": {
          "id": "kedy_postgres",

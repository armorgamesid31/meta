        "postgres": {
          "id": "kedy_postgres",
          "name": "Kedy Postgres"
        }
      }
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH eligible AS (\n  SELECT a.id AS \"appointmentId\", a.\"customerId\", a.\"salonId\"\n  FROM \"Appointment\" a\n  WHERE a.status = 'COMPLETED'\n    AND a.\"customerId\" IS NOT NULL\n    AND a.\"endTime\" > NOW() - INTERVAL '4 hours'\n    AND a.\"endTime\" < NOW() - INTERVAL '2 hours'\n    AND NOT EXISTS (\n      SELECT 1 FROM \"NotificationLog\" nl\n      WHERE nl.\"appointmentId\" = a.id AND nl.type = 'SATISFACTION_SURVEY'\n    )\n)\nSELECT * FROM eligible LIMIT 500;"
      },
      "id": "q_survey",
      "name": "Query: satisfaction surveys due",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [500, 700],
      "credentials": {
        "postgres": {
          "id": "kedy_postgres",
          "name": "Kedy Postgres"
        }
      }
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Google Maps review request: triggered on the customer's 3rd COMPLETED\n-- appointment, sent ONCE per (customer, salon). Hard-guarded by\n-- Customer.googleReviewRequestedAt set by backend on success.\nWITH counts AS (\n  SELECT a.\"customerId\", a.\"salonId\",\n         COUNT(*) FILTER (WHERE a.status = 'COMPLETED') AS completed_count,\n         MAX(a.\"endTime\") FILTER (WHERE a.status = 'COMPLETED') AS last_completed_at\n  FROM \"Appointment\" a\n  GROUP BY a.\"customerId\", a.\"salonId\"\n)\nSELECT c.id AS \"customerId\", c.\"salonId\"\nFROM \"Customer\" c\nJOIN counts cnt ON cnt.\"customerId\" = c.id AND cnt.\"salonId\" = c.\"salonId\"\nJOIN \"Salon\" s ON s.id = c.\"salonId\"\nWHERE c.\"googleReviewRequestedAt\" IS NULL\n  AND cnt.completed_count >= 3\n  AND cnt.last_completed_at > NOW() - INTERVAL '2 hours'\n  AND s.\"googleMapsUrl\" IS NOT NULL\n  AND s.\"googleMapsUrl\" <> ''\nLIMIT 500;"
      },
      "id": "q_google_maps",
      "name": "Query: Google Maps review (3rd appt)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [500, 850],
      "credentials": {
        "postgres": {
          "id": "kedy_postgres",
          "name": "Kedy Postgres"
        }
      }
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Birthday: today is customer's birthday and we haven't sent in the\n-- last 300 days (per-year dedup). Salon must have birthday offer\n-- configured (backend short-circuits if empty).\nSELECT c.id AS \"customerId\", c.\"salonId\"\nFROM \"Customer\" c\nJOIN \"Salon\" s ON s.id = c.\"salonId\"\nWHERE c.\"birthDate\" IS NOT NULL\n  AND c.\"acceptMarketing\" = true\n  AND EXTRACT(MONTH FROM c.\"birthDate\") = EXTRACT(MONTH FROM NOW())\n  AND EXTRACT(DAY FROM c.\"birthDate\") = EXTRACT(DAY FROM NOW())\n  AND s.\"birthdayDiscountText\" IS NOT NULL\n  AND s.\"birthdayDiscountText\" <> ''\n  AND s.\"birthdayValidityText\" IS NOT NULL\n  AND s.\"birthdayValidityText\" <> ''\n  AND NOT EXISTS (\n    SELECT 1 FROM \"NotificationLog\" nl\n    WHERE nl.\"customerId\" = c.id AND nl.type = 'BIRTHDAY'\n      AND nl.\"sentAt\" > NOW() - INTERVAL '300 days'\n  )\nLIMIT 500;"
      },
      "id": "q_birthday",
      "name": "Query: birthdays today",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [500, 1000],
      "credentials": {
        "postgres": {
          "id": "kedy_postgres",
          "name": "Kedy Postgres"
        }
      }
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Winback: customer's last appointment is 45-46 days ago, hasn't been\n-- winback-targeted in last 30 days, opted into marketing, salon has\n-- winback offer set.\nWITH last_visits AS (\n  SELECT a.\"customerId\", a.\"salonId\", MAX(a.\"startTime\") AS last_visit\n  FROM \"Appointment\" a\n  WHERE a.status = 'COMPLETED'\n  GROUP BY a.\"customerId\", a.\"salonId\"\n)\nSELECT c.id AS \"customerId\", c.\"salonId\"\nFROM \"Customer\" c\nJOIN last_visits lv ON lv.\"customerId\" = c.id AND lv.\"salonId\" = c.\"salonId\"\nJOIN \"Salon\" s ON s.id = c.\"salonId\"\nWHERE c.\"acceptMarketing\" = true\n  AND lv.last_visit < NOW() - INTERVAL '45 days'\n  AND lv.last_visit > NOW() - INTERVAL '46 days'\n  AND s.\"winbackDiscountText\" IS NOT NULL\n  AND s.\"winbackDiscountText\" <> ''\n  AND s.\"winbackValidityText\" IS NOT NULL\n  AND s.\"winbackValidityText\" <> ''\n  AND NOT EXISTS (\n    SELECT 1 FROM \"NotificationLog\" nl\n    WHERE nl.\"customerId\" = c.id AND nl.type = 'WINBACK'\n      AND nl.\"sentAt\" > NOW() - INTERVAL '30 days'\n  )\nLIMIT 500;"
      },
      "id": "q_winback",
      "name": "Query: winback candidates",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [500, 1150],
      "credentials": {
        "postgres": {
          "id": "kedy_postgres",
          "name": "Kedy Postgres"
        }
      }
    },


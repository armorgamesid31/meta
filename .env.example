# =========================
# DATABASE
# =========================
# Production pool params (REQUIRED for 1000+ salon scale):
#   connection_limit=75       — concurrent connections per backend instance
#   pool_timeout=20           — wait this many seconds if pool exhausted
#   connect_timeout=10        — initial TCP connect timeout
#   statement_cache_size=0    — disable prepared statement cache (pgbouncer-friendly)
# n8n batch sends up to 30 concurrent per branch × 8 branches = peak ~240
# concurrent backend calls. Each call uses 2-3 DB queries (10-50ms each).
# Mobile + booking + webhook traffic adds 15-25 baseline connections.
# 75 connection limit handles peaks comfortably for ~1000 salons.
# Postgres server should have max_connections >= 200.
DATABASE_URL=postgresql://username:password@localhost:5432/salon_asistan?connection_limit=75&pool_timeout=20&connect_timeout=10&statement_cache_size=0

# =========================
# SERVER
# =========================
PORT=3000
REDIS_URL=redis://127.0.0.1:6379
REALTIME_WS_HEARTBEAT_MS=25000
REALTIME_REPLAY_LIMIT=300

# CORS origins - production domain'lerini buraya ekleyin
# Ã–rnek: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# =========================
# FRONTEND
# =========================
# Ana domain - magic linkler ve booking URL'leri iÃ§in
# Production'da deÄŸiÅŸtirmek iÃ§in sadece bu deÄŸiÅŸkeni gÃ¼ncelleyin
FRONTEND_URL=https://yourdomain.com
BOOKING_BASE_URL=https://yourdomain.com

# =========================
# SECURITY
# =========================
# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secure-jwt-secret-here

# =========================
# CONTENT MODULE (PHASE 1)
# =========================
# Global content write/publish allowlist (comma separated emails)
CONTENT_ADMIN_EMAILS=ops@example.com,product@example.com

# Runtime content cache TTL in seconds
CONTENT_RUNTIME_CACHE_SECONDS=60

# Internal endpoints (n8n / server-to-server)
INTERNAL_API_KEY=replace-with-strong-internal-key
CONVERSATION_HUMAN_ACTIVE_MINUTES=360
CHAKRA_WHATSAPP_SEND_URL=
CHAKRA_API_TOKEN=
CHAKRA_PASSTHROUGH_WEBHOOK_URL=https://app.berkai.shop/api/webhooks/whatsapp

# Public Meta webhook verify tokens (use shared or channel-specific)
META_WEBHOOK_VERIFY_TOKEN=
META_INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Backend -> n8n normalized forward
N8N_NORMALIZED_WEBHOOK_URL=
N8N_NORMALIZED_INSTAGRAM_WEBHOOK_URL=
N8N_NORMALIZED_WHATSAPP_WEBHOOK_URL=
N8N_INTERNAL_API_KEY=

# Mobile notification V1
# Prefer FCM_SERVICE_ACCOUNT_BASE64 in production deployments.
# Generate a Firebase service account JSON, then base64-encode the raw file contents.
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_BASE64=
HANDOVER_REMINDER_INTERVAL_MINUTES=30
HANDOVER_REMINDER_MAX_COUNT=6

# Data Import Wizard (Cloudflare R2 + OCR)
IMPORTS_R2_ENDPOINT=
IMPORTS_R2_BUCKET=
IMPORTS_R2_ACCESS_KEY_ID=
IMPORTS_R2_SECRET_ACCESS_KEY=
IMPORTS_R2_REGION=auto
IMPORTS_PUBLIC_BASE_URL=https://cdn.kedyapp.com
IMPORTS_PRESIGN_TTL_SECONDS=900
IMPORTS_RETENTION_DAYS=30
IMPORTS_OCR_WEBHOOK_URL=
IMPORTS_OCR_WEBHOOK_TIMEOUT_MS=15000
IMPORTS_OCR_AUTO_TRIGGER=true

# =========================
# META DIRECT (Instagram + WhatsApp Cloud API)
# =========================
META_APP_ID=
META_APP_SECRET=
META_INSTAGRAM_APP_ID=
META_INSTAGRAM_APP_SECRET=
META_STATE_SECRET=
# Optional: if empty, callback URL is inferred from request host
META_REDIRECT_URI=
# Optional
META_GRAPH_VERSION=v23.0
# Optional: Login for Business config IDs (for Embedded Signup-style flow)
META_WHATSAPP_CONFIG_ID=
META_INSTAGRAM_CONFIG_ID=
# Optional comma-separated overrides
META_INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_manage_messages
META_INSTAGRAM_SUBSCRIBED_FIELDS=messages,messaging_postbacks,messaging_seen,message_reactions
META_WHATSAPP_SCOPES=whatsapp_business_management,whatsapp_business_messaging

# =========================
# VITE (Frontend Configuration)
# =========================
# Production deployment - no reverse proxy needed
VITE_BASE_URL=/

# API proxy target (backend server)
# Production'da aynÄ± domain kullanÄ±yorsanÄ±z boÅŸ bÄ±rakÄ±n (recommended)
# FarklÄ± domain kullanÄ±yorsanÄ±z tam URL girin
# VITE_API_PROXY_TARGET=

# Production API base URL (empty for relative paths)
# VITE_API_BASE_URL=
STRIPE_PRICE_PROFESSIONAL_PLUS=price_xxx
STRIPE_PRICE_TEMEL=price_xxx
STRIPE_COUPON_PROFESSIONAL_PLUS_INTRO=coupon_xxx

# =========================
# SENTRY
# =========================
# Set this in production to enable Sentry error tracking. Leave empty to disable.
SENTRY_DSN=

# =========================
# VERIFICATION SYSTEM (UTILITY-link based)
# =========================
# Magic-link TTL (minutes) for phone/email verification links.
VERIFICATION_LINK_TTL_MINUTES=15
# Cooldown (seconds) between resend attempts on the same verification id.
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# Landing page base URLs. Kedy auth flows go to BASE_URL_KEDY; salon customer
# flows go to BASE_URL_CUSTOMER (salon-branded booking subdomain).
VERIFICATION_BASE_URL_KEDY=https://kedyapp.com
VERIFICATION_BASE_URL_CUSTOMER=https://app.berkai.shop

# =========================
# EMAIL (Amazon SES via SMTP)
# =========================
# Required for salon signup email verification (UTILITY-link flow).
# Credentials come from an SES SMTP IAM user (e.g. kedy-ses-smtp-transactional).
# The sender domain must be verified in SES; we use mail.kedyapp.com to
# isolate transactional reputation from the apex domain.
SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Kedy <noreply@mail.kedyapp.com>


# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql://username:password@localhost:5432/salon_asistan

# =========================
# SERVER
# =========================
PORT=3000

# CORS origins - production domain'lerini buraya ekleyin
# Örnek: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# =========================
# FRONTEND
# =========================
# Ana domain - magic linkler ve booking URL'leri için
# Production'da değiştirmek için sadece bu değişkeni güncelleyin
FRONTEND_URL=https://yourdomain.com

# =========================
# SECURITY
# =========================
# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secure-jwt-secret-here

# =========================
# META DIRECT (Instagram + WhatsApp Cloud API)
# =========================
META_APP_ID=
META_APP_SECRET=
META_STATE_SECRET=
# Optional: if empty, callback URL is inferred from request host
META_REDIRECT_URI=
# Optional
META_GRAPH_VERSION=v23.0
# Optional comma-separated overrides
META_INSTAGRAM_SCOPES=pages_show_list,pages_read_engagement,pages_manage_metadata,instagram_basic,instagram_manage_messages
META_WHATSAPP_SCOPES=business_management,whatsapp_business_management,whatsapp_business_messaging

# =========================
# VITE (Frontend Configuration)
# =========================
# Production deployment - no reverse proxy needed
VITE_BASE_URL=/

# API proxy target (backend server)
# Production'da aynı domain kullanıyorsanız boş bırakın (recommended)
# Farklı domain kullanıyorsanız tam URL girin
# VITE_API_PROXY_TARGET=

# Production API base URL (empty for relative paths)
# VITE_API_BASE_URL=

# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql://username:password@localhost:5432/salon_asistan

# =========================
# SERVER
# =========================
PORT=3000

# CORS origins - production domain'lerini buraya ekleyin
# Örnek: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# =========================
# FRONTEND
# =========================
# Ana domain - magic linkler ve booking URL'leri için
# Production'da değiştirmek için sadece bu değişkeni güncelleyin
FRONTEND_URL=https://yourdomain.com
BOOKING_BASE_URL=https://yourdomain.com

# =========================
# SECURITY
# =========================
# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secure-jwt-secret-here

# =========================
# CONTENT MODULE (PHASE 1)
# =========================
# Global content write/publish allowlist (comma separated emails)
CONTENT_ADMIN_EMAILS=ops@example.com,product@example.com

# Runtime content cache TTL in seconds
CONTENT_RUNTIME_CACHE_SECONDS=60

# Internal endpoints (n8n / server-to-server)
INTERNAL_API_KEY=replace-with-strong-internal-key
CONVERSATION_HUMAN_ACTIVE_MINUTES=360
CHAKRA_WHATSAPP_SEND_URL=
CHAKRA_API_TOKEN=
CHAKRA_PASSTHROUGH_WEBHOOK_URL=https://app.berkai.shop/api/webhooks/whatsapp

# Public Meta webhook verify tokens (use shared or channel-specific)
META_WEBHOOK_VERIFY_TOKEN=
META_INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Backend -> n8n normalized forward
N8N_NORMALIZED_WEBHOOK_URL=
N8N_NORMALIZED_INSTAGRAM_WEBHOOK_URL=
N8N_NORMALIZED_WHATSAPP_WEBHOOK_URL=
N8N_INTERNAL_API_KEY=

# Mobile notification V1
# Prefer FCM_SERVICE_ACCOUNT_BASE64 in production deployments.
# Generate a Firebase service account JSON, then base64-encode the raw file contents.
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_BASE64=
HANDOVER_REMINDER_INTERVAL_MINUTES=30
HANDOVER_REMINDER_MAX_COUNT=6

# Data Import Wizard (Cloudflare R2 + OCR)
IMPORTS_R2_ENDPOINT=
IMPORTS_R2_BUCKET=
IMPORTS_R2_ACCESS_KEY_ID=
IMPORTS_R2_SECRET_ACCESS_KEY=
IMPORTS_R2_REGION=auto
IMPORTS_PUBLIC_BASE_URL=https://cdn.kedyapp.com
IMPORTS_PRESIGN_TTL_SECONDS=900
IMPORTS_RETENTION_DAYS=30
IMPORTS_OCR_WEBHOOK_URL=
IMPORTS_OCR_WEBHOOK_TIMEOUT_MS=15000
IMPORTS_OCR_AUTO_TRIGGER=true

# =========================
# META DIRECT (Instagram + WhatsApp Cloud API)
# =========================
META_APP_ID=
META_APP_SECRET=
META_INSTAGRAM_APP_ID=
META_INSTAGRAM_APP_SECRET=
META_STATE_SECRET=
# Optional: if empty, callback URL is inferred from request host
META_REDIRECT_URI=
# Optional
META_GRAPH_VERSION=v23.0
# Optional: Login for Business config IDs (for Embedded Signup-style flow)
META_WHATSAPP_CONFIG_ID=
META_INSTAGRAM_CONFIG_ID=
# Optional comma-separated overrides
META_INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_manage_messages
META_INSTAGRAM_SUBSCRIBED_FIELDS=messages,messaging_postbacks,messaging_seen,message_reactions
META_WHATSAPP_SCOPES=whatsapp_business_management,whatsapp_business_messaging

# =========================
# VITE (Frontend Configuration)
# =========================
# Production deployment - no reverse proxy needed
VITE_BASE_URL=/

# API proxy target (backend server)
# Production'da aynı domain kullanıyorsanız boş bırakın (recommended)
# Farklı domain kullanıyorsanız tam URL girin
# VITE_API_PROXY_TARGET=

# Production API base URL (empty for relative paths)
# VITE_API_BASE_URL=
